---
import PasswordGate from '../components/PasswordGate.astro';
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Affiliate Intelligence — LiveChannel Flywheel' } = Astro.props;
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Flywheel Affiliate</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0f1117;
        --surface: #1a1d27;
        --surface-hover: #242836;
        --text: #e2e8f0;
        --text-muted: #94a3b8;
        --accent: #10b981;
        --accent-hover: #059669;
        --border: #2d3348;
        --green: #10b981;
        --yellow: #f59e0b;
        --orange: #f97316;
        --red: #ef4444;
        --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --mono: 'JetBrains Mono', 'Fira Code', monospace;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        font-size: 15px;
        line-height: 1.7;
        min-height: 100vh;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; color: var(--accent-hover); }

      /* Header */
      header {
        border-bottom: 1px solid var(--border);
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      header .logo {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.02em;
        text-decoration: none;
      }
      header .logo:hover { text-decoration: none; }
      header .logo span { color: var(--accent); }

      nav { display: flex; gap: 0.15rem; }
      .nav-group { position: relative; }
      .nav-group-label {
        color: var(--text-muted);
        font-size: 0.82rem;
        font-weight: 500;
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        cursor: default;
        user-select: none;
        transition: color 0.15s, background 0.15s;
      }
      .nav-group:hover .nav-group-label { color: var(--text); background: var(--surface); }
      .nav-group-label.active { color: var(--accent); background: var(--surface); }
      .nav-dropdown {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        margin-top: 0.25rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.35rem;
        min-width: 170px;
        z-index: 100;
      }
      .nav-group:hover .nav-dropdown { display: block; }
      .nav-dropdown a {
        display: block;
        color: var(--text-muted);
        font-size: 0.82rem;
        font-weight: 500;
        padding: 0.4rem 0.75rem;
        border-radius: 5px;
        text-decoration: none;
      }
      .nav-dropdown a:hover {
        color: var(--text);
        background: var(--surface-hover);
        text-decoration: none;
      }
      .nav-dropdown a.active { color: var(--accent); }

      /* Main */
      main {
        max-width: 860px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      /* Footer */
      footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem 2rem;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.78rem;
      }

      /* Badge */
      .badge {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 0.15rem 0.55rem;
        border-radius: 4px;
        background: var(--surface);
        color: var(--text-muted);
        border: 1px solid var(--border);
      }
      .badge.green { background: rgba(16, 185, 129, 0.15); color: var(--green); border-color: rgba(16, 185, 129, 0.3); }
      .badge.yellow { background: rgba(245, 158, 11, 0.15); color: var(--yellow); border-color: rgba(245, 158, 11, 0.3); }
      .badge.orange { background: rgba(249, 115, 22, 0.15); color: var(--orange); border-color: rgba(249, 115, 22, 0.3); }
      .badge.red { background: rgba(239, 68, 68, 0.15); color: var(--red); border-color: rgba(239, 68, 68, 0.3); }

      /* Score bar */
      .score-bar {
        background: var(--surface);
        border-radius: 4px;
        height: 8px;
        overflow: hidden;
        border: 1px solid var(--border);
      }
      .score-bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.3s;
      }
      .score-bar-fill.green { background: var(--green); }
      .score-bar-fill.yellow { background: var(--yellow); }
      .score-bar-fill.orange { background: var(--orange); }
      .score-bar-fill.red { background: var(--red); }

      /* Card */
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.25rem;
        transition: border-color 0.15s, background 0.15s;
      }
      .card:hover {
        border-color: rgba(16, 185, 129, 0.3);
        background: var(--surface-hover);
      }
      .card a { color: inherit; text-decoration: none; }
      .card a:hover { text-decoration: none; }

      /* Prose */
      .prose h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem; letter-spacing: -0.02em; }
      .prose h2 { font-size: 1.3rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; letter-spacing: -0.01em; color: var(--text); }
      .prose h3 { font-size: 1.05rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; color: var(--text); }
      .prose p { margin-bottom: 1rem; color: var(--text-muted); }
      .prose ul, .prose ol { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--text-muted); }
      .prose li { margin-bottom: 0.35rem; }
      .prose strong { color: var(--text); font-weight: 600; }
      .prose code { font-family: var(--mono); font-size: 0.85em; background: var(--surface); padding: 0.15em 0.4em; border-radius: 4px; }
      .prose table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.9rem; }
      .prose th, .prose td { padding: 0.5rem 0.75rem; border: 1px solid var(--border); text-align: left; }
      .prose th { background: var(--surface); color: var(--text); font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; }
      .prose td { color: var(--text-muted); }
      .prose blockquote { border-left: 3px solid var(--accent); padding-left: 1rem; margin: 1rem 0; color: var(--text-muted); font-style: italic; }
      .prose hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

      /* Utilities */
      .text-muted { color: var(--text-muted); }
      .text-accent { color: var(--accent); }
      .text-sm { font-size: 0.85rem; }
      .text-xs { font-size: 0.75rem; }
      .font-mono { font-family: var(--mono); }
      .mt-1 { margin-top: 0.5rem; }
      .mt-2 { margin-top: 1rem; }
      .mt-3 { margin-top: 1.5rem; }
      .mb-1 { margin-bottom: 0.5rem; }
      .mb-2 { margin-bottom: 1rem; }
      .mb-3 { margin-bottom: 1.5rem; }
      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
      .flex { display: flex; }
      .flex-between { display: flex; justify-content: space-between; align-items: center; }
      .gap-1 { gap: 0.5rem; }
      .gap-2 { gap: 1rem; }

      /* Mobile */
      .mobile-menu-toggle { display: none; }

      @media (max-width: 768px) {
        header {
          flex-wrap: wrap;
          padding: 0.75rem 1rem;
        }
        nav {
          flex-wrap: wrap;
          gap: 0.25rem;
        }
        .nav-dropdown {
          position: static;
          margin-top: 0;
          border: none;
          background: transparent;
          padding: 0 0 0 1rem;
        }
        .grid-2, .grid-3 { grid-template-columns: 1fr; }
        main { padding: 1.5rem 1rem 3rem; }
      }
    </style>
  </head>
  <body>
    <PasswordGate />
    <header>
      <a href="/" class="logo">&#x1f41c; <span>Affiliate</span> Intelligence</a>
      <nav>
        <div class="nav-group">
          <span class:list={['nav-group-label', (path.startsWith('/vendors') || path.startsWith('/research')) && 'active']}>Intelligence</span>
          <div class="nav-dropdown">
            <a href="/vendors/" class:list={[path.startsWith('/vendors') && 'active']}>Vendors</a>
            <a href="/research/" class:list={[path.startsWith('/research') && 'active']}>Research</a>
          </div>
        </div>
        <div class="nav-group">
          <span class:list={['nav-group-label', path.startsWith('/briefings') && 'active']}>Briefings</span>
          <div class="nav-dropdown">
            <a href="/briefings/" class:list={[path.startsWith('/briefings') && 'active']}>Daily Briefings</a>
          </div>
        </div>
        <div class="nav-group">
          <span class:list={['nav-group-label', path === '/about/' && 'active']}>About</span>
          <div class="nav-dropdown">
            <a href="/about/" class:list={[path === '/about/' && 'active']}>Mission</a>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      Mac Ant — Flywheel Affiliate Intelligence Engine
    </footer>
  </body>
</html>
