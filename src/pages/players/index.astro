---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const players = await getCollection('players');

const typeGroups: Record<string, { label: string; description: string; items: typeof players }> = {
  'network': { label: 'Affiliate Networks', description: 'Platforms connecting brands with affiliates', items: [] },
  'platform': { label: 'Platforms & Tools', description: 'Technology for managing affiliate programs', items: [] },
  'publisher': { label: 'Publishers & Partners', description: 'Sites and services that drive affiliate traffic', items: [] },
  'ai-tech': { label: 'AI & Emerging Tech', description: 'AI-powered affiliate and commerce technology', items: [] },
  'industry-body': { label: 'Industry Bodies', description: 'Trade associations and standards organizations', items: [] },
};

for (const p of players) {
  const t = p.data.type;
  if (typeGroups[t]) {
    typeGroups[t].items.push(p);
  }
}

function relevanceBadge(r: string): string {
  switch (r) {
    case 'high': return 'green';
    case 'medium': return 'yellow';
    case 'low': return '';
    default: return '';
  }
}
---

<Base title="Who's Who in Affiliate">
  <h1 class="page-title">Who's Who in Affiliate</h1>
  <p class="page-intro">A comprehensive directory of the players shaping the affiliate commerce landscape. Each profile is continuously updated by our research pipeline.</p>

  <div class="player-count">{players.length} players tracked</div>

  {Object.entries(typeGroups).filter(([, v]) => v.items.length > 0).map(([key, { label, description, items }]) => (
    <section class="type-section">
      <div class="type-header">
        <h2 class="type-title">{label}</h2>
        <p class="type-description">{description}</p>
      </div>
      <div class="player-grid">
        {items.sort((a, b) => {
          const relevanceOrder = { high: 0, medium: 1, low: 2 };
          const ra = relevanceOrder[a.data.vendorRelevance] ?? 1;
          const rb = relevanceOrder[b.data.vendorRelevance] ?? 1;
          if (ra !== rb) return ra - rb;
          return a.data.name.localeCompare(b.data.name);
        }).map((p) => (
          <a href={`/players/${p.id.replace(/\.md$/, '')}/`} class="player-card">
            <div class="card-header">
              <h3 class="card-name">{p.data.name}</h3>
              <span class={`badge ${relevanceBadge(p.data.vendorRelevance)}`}>
                {p.data.vendorRelevance}
              </span>
            </div>

            <p class="card-description">{p.data.description}</p>

            {p.data.keyStats && p.data.keyStats.length > 0 && (
              <div class="card-stats">
                {p.data.keyStats.slice(0, 3).map((s) => (
                  <div class="stat">
                    <span class="stat-value">{s.value}</span>
                    <span class="stat-label">{s.label}</span>
                  </div>
                ))}
              </div>
            )}

            <div class="card-footer">
              {p.data.headquarters && <span class="footer-item">{p.data.headquarters}</span>}
              {p.data.founded && <span class="footer-item">Est. {p.data.founded}</span>}
              <span class="footer-item">{p.data.lastUpdated}</span>
            </div>

            <span class="card-link">View profile &rarr;</span>
          </a>
        ))}
      </div>
    </section>
  ))}
</Base>

<style>
  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
  }
  .page-intro {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
    max-width: 640px;
  }
  .player-count {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-family: var(--mono);
  }

  .type-section {
    margin-bottom: 3.5rem;
  }
  .type-header {
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--border);
  }
  .type-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }
  .type-description {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .player-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .player-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .player-card:hover {
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
    border-color: #d1d5db;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .card-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    flex-grow: 1;
  }

  .card-stats {
    display: flex;
    gap: 1.5rem;
    padding: 0.75rem 0;
    border-top: 1px solid var(--border);
    margin-bottom: 0.75rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .stat-value {
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--text);
    font-family: var(--mono);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .stat-label {
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-footer {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .footer-item {
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .footer-item:not(:last-child)::after {
    content: "\00b7";
    margin-left: 1rem;
    color: var(--border);
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
  }
  .player-card:hover .card-link {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .player-grid {
      grid-template-columns: 1fr;
    }
    .card-stats { gap: 1rem; flex-wrap: wrap; }
  }
</style>
