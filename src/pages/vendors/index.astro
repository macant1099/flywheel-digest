---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const vendors = await getCollection('vendors');
const sorted = vendors.sort((a, b) => b.data.afareScore - a.data.afareScore);

function bandClass(band: string): string {
  switch (band) {
    case 'Leading': return 'green';
    case 'Established': return 'yellow';
    case 'Developing': return 'orange';
    case 'Early': return 'red';
    default: return '';
  }
}

function scoreColor(score: number): string {
  if (score >= 75) return 'green';
  if (score >= 60) return 'yellow';
  if (score >= 45) return 'orange';
  return 'red';
}
---

<Base title="Vendors">
  <h1 class="page-title">Vendor Scorecards</h1>
  <p class="page-intro">AFARE (Affiliate Footprint & Readiness Evaluation) scores across {vendors.length} tracked vendors. Each vendor is evaluated on 5 dimensions and 25 criteria on a 100-point scale.</p>

  <div class="page-meta">{vendors.length} vendors tracked</div>

  <div class="vendor-grid">
    {sorted.map((vendor) => (
      <a href={`/vendors/${vendor.id}/`} class="vendor-card">
        <div class="card-header">
          <div>
            <div class="vendor-name">
              <span class="vendor-emoji">{vendor.data.emoji}</span>
              <span>{vendor.data.name}</span>
            </div>
            <span class="vendor-category">{vendor.data.category}</span>
          </div>
          <span class={`badge ${bandClass(vendor.data.afareBand)}`}>{vendor.data.afareBand}</span>
        </div>

        <div class="score-section">
          <div class="score-display">
            <span class={`score-number ${scoreColor(vendor.data.afareScore)}-text`}>{vendor.data.afareScore}</span>
            <span class="score-max">/100</span>
          </div>
          <div class="score-bar-large">
            <div class={`score-bar-fill ${scoreColor(vendor.data.afareScore)}`} style={`width: ${vendor.data.afareScore}%`}></div>
          </div>
        </div>

        <div class="dimensions">
          {vendor.data.afareDimensions.map((dim) => (
            <div class="dim-row">
              <span class="dim-name">{dim.name}</span>
              <div class="dim-bar-wrap">
                <div class="score-bar">
                  <div class={`score-bar-fill ${scoreColor(dim.score * 5)}`} style={`width: ${(dim.score / dim.maxScore) * 100}%`}></div>
                </div>
              </div>
              <span class="dim-score">{dim.score}/{dim.maxScore}</span>
            </div>
          ))}
        </div>

        <div class="card-footer">
          <span class="footer-detail">{vendor.data.platform}</span>
          <span class="footer-detail">{vendor.data.websiteDisplay}</span>
          <span class="footer-detail">Evaluated {vendor.data.evaluationDate}</span>
        </div>

        <span class="card-link">View full scorecard &rarr;</span>
      </a>
    ))}
  </div>
</Base>

<style>
  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.5rem;
  }
  .page-intro {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
    max-width: 640px;
  }
  .page-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    font-family: var(--mono);
  }

  .vendor-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .vendor-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .vendor-card:hover {
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
    border-color: #d1d5db;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .vendor-name {
    font-weight: 700;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.2rem;
  }
  .vendor-emoji { font-size: 1.15rem; }
  .vendor-category {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .score-section {
    margin-bottom: 1.25rem;
  }
  .score-display {
    display: flex;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .score-number {
    font-size: 2.25rem;
    font-weight: 700;
    font-family: var(--mono);
    line-height: 1;
  }
  .score-max {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-family: var(--mono);
    margin-left: 0.1rem;
  }
  .score-bar-large {
    background: #f1f5f9;
    border-radius: 5px;
    height: 10px;
    overflow: hidden;
  }
  .score-bar-large .score-bar-fill {
    height: 100%;
    border-radius: 5px;
    transition: width 0.3s;
  }
  .green-text { color: var(--green); }
  .yellow-text { color: var(--yellow); }
  .orange-text { color: var(--orange); }
  .red-text { color: var(--red); }

  .dimensions {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  .dim-row {
    display: grid;
    grid-template-columns: 1fr 80px 42px;
    align-items: center;
    gap: 0.65rem;
  }
  .dim-name {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dim-bar-wrap { }
  .dim-score {
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--mono);
    color: var(--text);
    text-align: right;
  }

  .card-footer {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .footer-detail {
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .footer-detail:not(:last-child)::after {
    content: "\00b7";
    margin-left: 0.75rem;
    color: var(--border);
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
  }
  .vendor-card:hover .card-link {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .vendor-grid { grid-template-columns: 1fr; }
    .dim-row { grid-template-columns: 1fr 60px 38px; }
  }
</style>
