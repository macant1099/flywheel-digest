---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const vendors = await getCollection('vendors');
const sorted = vendors.sort((a, b) => b.data.afareScore - a.data.afareScore);

function bandClass(band: string): string {
  switch (band) {
    case 'Leading': return 'green';
    case 'Established': return 'yellow';
    case 'Developing': return 'orange';
    case 'Early': return 'red';
    default: return '';
  }
}

function scoreColor(score: number): string {
  if (score >= 75) return 'green';
  if (score >= 60) return 'yellow';
  if (score >= 45) return 'orange';
  return 'red';
}
---

<Base title="Vendors">
  <h1 class="page-title">Vendor Scorecards</h1>
  <p class="text-muted mb-3">AFARE (Affiliate Readiness Evaluation) scores across {vendors.length} tracked vendors. 5 dimensions, 25 criteria, 100-point scale.</p>

  <div class="vendor-list">
    {sorted.map((vendor) => (
      <a href={`/vendors/${vendor.id}/`} class="card vendor-card">
        <div class="vendor-top">
          <div class="vendor-info">
            <div class="vendor-name">
              <span class="vendor-emoji">{vendor.data.emoji}</span>
              <span>{vendor.data.name}</span>
            </div>
            <div class="text-xs text-muted">{vendor.data.category}</div>
            <div class="text-xs text-muted mt-1">{vendor.data.platform}</div>
          </div>
          <div class="vendor-score-block">
            <div class="vendor-score">
              <span class={`score-number ${scoreColor(vendor.data.afareScore)}-text`}>{vendor.data.afareScore}</span>
              <span class="score-max">/100</span>
            </div>
            <span class={`badge ${bandClass(vendor.data.afareBand)}`}>{vendor.data.afareBand}</span>
          </div>
        </div>
        <div class="dimensions-bars">
          {vendor.data.afareDimensions.map((dim) => (
            <div class="dim-row">
              <span class="dim-name">{dim.name}</span>
              <div class="dim-bar-wrap">
                <div class="score-bar">
                  <div class={`score-bar-fill ${scoreColor(dim.score * 5)}`} style={`width: ${(dim.score / dim.maxScore) * 100}%`}></div>
                </div>
              </div>
              <span class="dim-score font-mono">{dim.score}/{dim.maxScore}</span>
            </div>
          ))}
        </div>
      </a>
    ))}
  </div>
</Base>

<style>
  .page-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .vendor-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .vendor-card { display: block; text-decoration: none; }
  .vendor-card:hover { text-decoration: none; }
  .vendor-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
  }
  .vendor-name {
    font-weight: 600;
    font-size: 1.05rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.25rem;
  }
  .vendor-emoji { font-size: 1.2rem; }
  .vendor-score-block { text-align: right; }
  .vendor-score { margin-bottom: 0.35rem; }
  .score-number {
    font-size: 1.75rem;
    font-weight: 700;
    font-family: var(--mono);
  }
  .score-max {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: var(--mono);
  }
  .green-text { color: var(--green); }
  .yellow-text { color: var(--yellow); }
  .orange-text { color: var(--orange); }
  .red-text { color: var(--red); }

  .dimensions-bars {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .dim-row {
    display: grid;
    grid-template-columns: 160px 1fr 50px;
    align-items: center;
    gap: 0.75rem;
  }
  .dim-name {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .dim-bar-wrap { flex: 1; }
  .dim-score {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: right;
  }

  @media (max-width: 768px) {
    .dim-row { grid-template-columns: 120px 1fr 45px; }
  }
</style>
