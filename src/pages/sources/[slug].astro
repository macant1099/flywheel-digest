---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const sources = await getCollection('sources');
  return sources.map((s) => ({
    params: { slug: s.id.replace(/\.md$/, '') },
    props: { entry: s },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

function bucketLabel(b: string): string {
  switch (b) {
    case 'affinity-perks': return 'Affinity & Perks';
    case 'ams': return 'AMS';
    case 'affiliate-network': return 'Affiliate Network';
    case 'vertical-benchmark': return 'Vertical Benchmark';
    case 'community-creator': return 'Community / Creator';
    case 'diy-pattern': return 'DIY Pattern';
    default: return b;
  }
}

function implicationBadge(i: string): { label: string; cls: string } {
  switch (i) {
    case 'direct-competitor': return { label: 'Direct competitor', cls: 'red' };
    case 'adjacent': return { label: 'Adjacent', cls: 'yellow' };
    case 'inspiration': return { label: 'Inspiration', cls: 'blue' };
    case 'non-threat': return { label: 'Non-threat', cls: 'green' };
    default: return { label: i, cls: '' };
  }
}

const impl = implicationBadge(entry.data.livechannelImplication);
const hostFromUrl = (u?: string) => u ? u.replace(/^https?:\/\//, '').replace(/\/$/, '') : '';
---

<Base title={entry.data.name}>
  <div class="source-header">
    <a href="/sources/" class="back-link">&larr; All Sources</a>
    <h1 class="source-name">{entry.data.name}</h1>
    <div class="source-meta">
      <span class="badge blue">{bucketLabel(entry.data.bucket)}</span>
      <span class={`badge ${impl.cls}`}>{impl.label}</span>
      {entry.data.website && (
        <a href={entry.data.website} target="_blank" rel="noopener" class="text-sm">
          {hostFromUrl(entry.data.website)} &nearr;
        </a>
      )}
    </div>
    <p class="source-description">{entry.data.description}</p>
  </div>

  <div class="fact-grid">
    {entry.data.owner && (
      <div class="fact">
        <span class="fact-label">Owner</span>
        <span class="fact-value">{entry.data.owner}</span>
      </div>
    )}
    {entry.data.targetSourceType && entry.data.targetSourceType.length > 0 && (
      <div class="fact">
        <span class="fact-label">Target source type</span>
        <span class="fact-value">{entry.data.targetSourceType.join(', ')}</span>
      </div>
    )}
    {entry.data.sourceReach && (
      <div class="fact">
        <span class="fact-label">Reach</span>
        <span class="fact-value">{entry.data.sourceReach}</span>
      </div>
    )}
    {entry.data.pricingModel && (
      <div class="fact">
        <span class="fact-label">Pricing model</span>
        <span class="fact-value">{entry.data.pricingModel}</span>
      </div>
    )}
    {entry.data.vendorOnboarding && entry.data.vendorOnboarding !== 'unknown' && (
      <div class="fact">
        <span class="fact-label">Vendor onboarding</span>
        <span class="fact-value">{entry.data.vendorOnboarding}</span>
      </div>
    )}
    {entry.data.exclusivityPosture && entry.data.exclusivityPosture !== 'unknown' && (
      <div class="fact">
        <span class="fact-label">Exclusivity posture</span>
        <span class="fact-value">{entry.data.exclusivityPosture}</span>
      </div>
    )}
    {entry.data.authModel && (
      <div class="fact">
        <span class="fact-label">Auth model</span>
        <span class="fact-value">{entry.data.authModel}</span>
      </div>
    )}
    {entry.data.dataVisibility && (
      <div class="fact">
        <span class="fact-label">Data visibility</span>
        <span class="fact-value">{entry.data.dataVisibility}</span>
      </div>
    )}
    {entry.data.integrationDepth && (
      <div class="fact">
        <span class="fact-label">Integration depth</span>
        <span class="fact-value">{entry.data.integrationDepth}</span>
      </div>
    )}
    {entry.data.uxSurface && entry.data.uxSurface.length > 0 && (
      <div class="fact">
        <span class="fact-label">UX surface</span>
        <span class="fact-value">{entry.data.uxSurface.join(', ')}</span>
      </div>
    )}
    <div class="fact">
      <span class="fact-label">Last reviewed</span>
      <span class="fact-value">{entry.data.lastReviewed}</span>
    </div>
  </div>

  {(entry.data.strengths && entry.data.strengths.length > 0) || (entry.data.gaps && entry.data.gaps.length > 0) ? (
    <div class="sg-grid">
      {entry.data.strengths && entry.data.strengths.length > 0 && (
        <div class="sg-box strengths">
          <h3 class="sg-title">Strengths</h3>
          <ul>{entry.data.strengths.map((s) => <li>{s}</li>)}</ul>
        </div>
      )}
      {entry.data.gaps && entry.data.gaps.length > 0 && (
        <div class="sg-box gaps">
          <h3 class="sg-title">Gaps</h3>
          <ul>{entry.data.gaps.map((g) => <li>{g}</li>)}</ul>
        </div>
      )}
    </div>
  ) : null}

  <div class="prose">
    <Content />
  </div>

  {entry.data.citations && entry.data.citations.length > 0 && (
    <section class="citations">
      <h3 class="citations-title">Citations</h3>
      <ul>
        {entry.data.citations.map((c) => (
          <li><a href={c.url} target="_blank" rel="noopener">{c.label}</a></li>
        ))}
      </ul>
    </section>
  )}
</Base>

<style>
  .source-header { margin-bottom: 2rem; }
  .back-link {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .back-link:hover { color: var(--accent); }
  .source-name {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.6rem;
  }
  .source-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .source-description {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .fact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem 1.75rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .fact { display: flex; flex-direction: column; }
  .fact-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.15rem;
  }
  .fact-value {
    font-size: 0.88rem;
    color: var(--text);
    line-height: 1.5;
  }

  .sg-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .sg-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
  }
  .sg-box.strengths { border-left: 3px solid var(--green); }
  .sg-box.gaps { border-left: 3px solid var(--orange); }
  .sg-title {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text);
  }
  .sg-box ul { padding-left: 1.1rem; margin: 0; }
  .sg-box li {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.4rem;
  }

  .citations {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .citations-title {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .citations ul { padding-left: 1.1rem; }
  .citations li { font-size: 0.88rem; margin-bottom: 0.3rem; }

  @media (max-width: 768px) {
    .fact-grid, .sg-grid { grid-template-columns: 1fr; }
  }
</style>
