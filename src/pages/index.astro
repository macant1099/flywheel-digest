---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const vendors = await getCollection('vendors');
const research = await getCollection('research');
const briefings = await getCollection('briefings');
const players = await getCollection('players');

const sortedVendors = vendors.sort((a, b) => b.data.afareScore - a.data.afareScore);
const latestBriefing = briefings.sort((a, b) => b.data.date.localeCompare(a.data.date))[0];

function bandClass(band: string): string {
  switch (band) {
    case 'Leading': return 'green';
    case 'Established': return 'yellow';
    case 'Developing': return 'orange';
    case 'Early': return 'red';
    default: return '';
  }
}

function scoreColor(score: number): string {
  if (score >= 75) return 'green';
  if (score >= 60) return 'yellow';
  if (score >= 45) return 'orange';
  return 'red';
}
---

<Base title="Home">
  <section class="hero">
    <p class="hero-eyebrow">LiveChannel Flywheel</p>
    <h1>Affiliate Intelligence</h1>
    <p class="hero-sub">Research, scoring, and strategic intelligence for the affiliate commerce landscape. Helping vendors maximize revenue through smarter affiliate partnerships.</p>
  </section>

  <section class="metrics-bar">
    <div class="metric">
      <span class="metric-value">{vendors.length}</span>
      <span class="metric-label">Vendors Scored</span>
    </div>
    <div class="metric">
      <span class="metric-value">{players.length}</span>
      <span class="metric-label">Players Tracked</span>
    </div>
    <div class="metric">
      <span class="metric-value">{research.length}</span>
      <span class="metric-label">Research Files</span>
    </div>
    <div class="metric">
      <span class="metric-value">{briefings.length}</span>
      <span class="metric-label">Briefings</span>
    </div>
  </section>

  {latestBriefing && (
    <section class="section">
      <div class="section-header">
        <h2>Latest Briefing</h2>
        <a href="/briefings/" class="section-link">All briefings &rarr;</a>
      </div>
      <a href={`/briefings/${latestBriefing.id.replace(/\.md$/, '')}/`} class="briefing-feature">
        <span class="briefing-date">{latestBriefing.data.date}</span>
        <h3 class="briefing-title">{latestBriefing.data.title}</h3>
        {latestBriefing.data.summary && <p class="briefing-summary">{latestBriefing.data.summary}</p>}
        <span class="read-link">Read briefing &rarr;</span>
      </a>
    </section>
  )}

  <section class="section">
    <div class="section-header">
      <h2>Vendor Scorecards</h2>
      <a href="/vendors/" class="section-link">All vendors &rarr;</a>
    </div>
    <p class="section-description">AFARE scores measure affiliate footprint and readiness across 5 dimensions and 25 criteria.</p>
    <div class="vendor-grid">
      {sortedVendors.map((vendor) => (
        <a href={`/vendors/${vendor.id}/`} class="vendor-card">
          <div class="vendor-top">
            <div>
              <span class="vendor-emoji">{vendor.data.emoji}</span>
              <span class="vendor-name">{vendor.data.name}</span>
            </div>
            <span class={`badge ${bandClass(vendor.data.afareBand)}`}>{vendor.data.afareBand}</span>
          </div>
          <div class="vendor-score-row">
            <div class="vendor-score">
              <span class={`score-number ${scoreColor(vendor.data.afareScore)}-text`}>{vendor.data.afareScore}</span>
              <span class="score-max">/100</span>
            </div>
            <span class="vendor-category">{vendor.data.category}</span>
          </div>
          <div class="score-bar">
            <div class={`score-bar-fill ${scoreColor(vendor.data.afareScore)}`} style={`width: ${vendor.data.afareScore}%`}></div>
          </div>
          <div class="vendor-dimensions">
            {vendor.data.afareDimensions.map((d) => (
              <div class="dim">
                <span class="dim-label">{d.name}</span>
                <span class="dim-score">{d.score}/{d.maxScore}</span>
              </div>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2>Explore</h2>
    </div>
    <div class="nav-grid">
      <a href="/players/" class="nav-card">
        <h3>Who's Who</h3>
        <p>{players.length} players across networks, platforms, publishers, AI, and industry bodies</p>
        <span class="read-link">Browse directory &rarr;</span>
      </a>
      <a href="/research/" class="nav-card">
        <h3>Research</h3>
        <p>{research.length} files tracking affiliate networks, vertical landscapes, and industry trends</p>
        <span class="read-link">View research &rarr;</span>
      </a>
      <a href="/briefings/" class="nav-card">
        <h3>Briefings</h3>
        <p>Daily intelligence briefings and weekly newsletters for the affiliate landscape</p>
        <span class="read-link">Read briefings &rarr;</span>
      </a>
    </div>
  </section>
</Base>

<style>
  /* Hero */
  .hero {
    padding: 3rem 0 2rem;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .hero h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    color: var(--text);
  }
  .hero-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 560px;
    line-height: 1.7;
  }

  /* Metrics */
  .metrics-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .metric {
    text-align: center;
    padding: 1.25rem 1rem;
    background: var(--surface);
  }
  .metric-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    font-family: var(--mono);
    margin-bottom: 0.15rem;
  }
  .metric-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Sections */
  .section {
    margin-top: 3.5rem;
  }
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .section-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .section-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--accent);
  }
  .section-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  /* Latest Briefing */
  .briefing-feature {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s;
    margin-top: 1rem;
  }
  .briefing-feature:hover {
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    border-color: #d1d5db;
  }
  .briefing-date {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: var(--mono);
    display: block;
    margin-bottom: 0.5rem;
  }
  .briefing-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  .briefing-summary {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }
  .read-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
  }

  /* Vendor Cards */
  .vendor-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .vendor-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .vendor-card:hover {
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    border-color: #d1d5db;
  }
  .vendor-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }
  .vendor-emoji { font-size: 1.1rem; margin-right: 0.35rem; }
  .vendor-name { font-weight: 600; font-size: 1rem; }
  .vendor-score-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .vendor-score { display: flex; align-items: baseline; }
  .score-number {
    font-size: 2rem;
    font-weight: 700;
    font-family: var(--mono);
    line-height: 1;
  }
  .score-max {
    font-size: 0.88rem;
    color: var(--text-muted);
    font-family: var(--mono);
    margin-left: 0.1rem;
  }
  .vendor-category {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .green-text { color: var(--green); }
  .yellow-text { color: var(--yellow); }
  .orange-text { color: var(--orange); }
  .red-text { color: var(--red); }
  .vendor-dimensions {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .dim {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .dim-label {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .dim-score {
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--mono);
    color: var(--text);
  }

  /* Explore */
  .nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.25rem;
    margin-top: 1rem;
  }
  .nav-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .nav-card:hover {
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    border-color: #d1d5db;
  }
  .nav-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .nav-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: 0.75rem;
  }

  @media (max-width: 768px) {
    .hero h1 { font-size: 1.75rem; }
    .metrics-bar { grid-template-columns: repeat(2, 1fr); }
    .vendor-grid { grid-template-columns: 1fr; }
    .nav-grid { grid-template-columns: 1fr; }
  }
</style>
