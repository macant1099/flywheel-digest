---
// Client-side password gate — same pattern as aces-portal
---

<div id="password-gate" class="gate-overlay">
  <div class="gate-card">
    <div class="gate-logo">AFARE</div>
    <h2>Affiliate Footprint & Readiness Evaluation</h2>
    <p class="gate-sub">LiveChannel Intelligence Portal</p>
    <form id="gate-form">
      <input
        type="password"
        id="gate-password"
        placeholder="Enter access code"
        autocomplete="off"
        autofocus
      />
      <button type="submit">Access Portal</button>
      <p id="gate-error" class="gate-error" hidden>Invalid access code</p>
    </form>
  </div>
</div>

<style>
  .gate-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gate-overlay.hidden {
    display: none;
  }

  .gate-card {
    text-align: center;
    max-width: 380px;
    width: 100%;
    padding: 2.5rem;
  }

  .gate-logo {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .gate-card h2 {
    font-size: 1rem;
    color: var(--text);
    font-weight: 400;
    margin-bottom: 0.25rem;
  }

  .gate-sub {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 2rem;
  }

  #gate-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  #gate-password {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  #gate-password:focus {
    border-color: var(--accent);
  }

  button[type="submit"] {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border: none;
    background: var(--accent);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  button[type="submit"]:hover {
    background: var(--accent-hover);
  }

  .gate-error {
    color: #ef4444;
    font-size: 0.85rem;
  }
</style>

<script>
  function checkAuth(): boolean {
    return sessionStorage.getItem('afare-auth') === 'granted';
  }

  function grantAuth(): void {
    sessionStorage.setItem('afare-auth', 'granted');
  }

  const gate = document.getElementById('password-gate')!;
  const form = document.getElementById('gate-form')!;
  const input = document.getElementById('gate-password') as HTMLInputElement;
  const error = document.getElementById('gate-error')!;

  if (checkAuth()) {
    gate.classList.add('hidden');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const val = input.value.trim();
    if (val === 'livechannel2026') {
      grantAuth();
      gate.classList.add('hidden');
    } else {
      error.hidden = false;
      input.value = '';
      input.focus();
    }
  });
</script>
